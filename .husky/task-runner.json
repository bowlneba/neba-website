{
  "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
  "tasks": [
    {
      "name": "dotnet-format",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "format"
      ],
      "include": [
        "**/*.cs"
      ]
    },
    {
      "name": "git-add-formatted",
      "group": "pre-commit",
      "command": "git",
      "args": [
        "add",
        "--update"
      ],
      "include": [
        "**/*.cs"
      ]
    }
  ]
}