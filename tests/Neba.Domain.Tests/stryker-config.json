{
  "stryker-config": {
    "project": "Neba.Domain.csproj",
    "test-runner": "mtp",
    "reporters": ["html", "json", "progress"],
    "project-info": {
      "name": "github.com/bowlneba/neba-website",
      "module": "domain"
    },
    "thresholds": {
      "high": 95,
      "low": 90,
      "break": 85
    },
    "ignore-mutations": ["string"],
    "additional-timeout": 30000,
    "ignore-methods": [
      "ArgumentNullException.ThrowIfNull",
      "ArgumentException.ThrowIfNullOrEmpty",
      "Guard.*",
      "Log.*",
      "Logger.*",
      "LanePairs"
    ],
    "mutate": [
      "**/*.cs",
      "!**/AssemblyInfo.cs",
      "!**/*Id.cs"
    ]
  }
}
