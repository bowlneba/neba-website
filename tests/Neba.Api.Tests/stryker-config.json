{
  "stryker-config": {
    "project": "Neba.Api.csproj",
    "test-runner": "mtp",
    "reporters": ["html", "json", "progress"],
    "project-info": {
      "name": "github.com/bowlneba/neba-website",
      "module": "api"
    },
    "thresholds": {
      "high": 90,
      "low": 80,
      "break": 75
    },
    "ignore-mutations": ["string", "Update", "Linq"],
    "additional-timeout": 30000,
    "ignore-methods": [
      "ArgumentNullException.ThrowIfNull",
      "ArgumentException.ThrowIfNullOrEmpty",
      "Guard.*",
      "Log.*",
      "Logger.*",
      "Description",
      "Options",
      "Get",
      "Version"
    ],
    "mutate": [
      "**/*.cs",
      "!**/AssemblyInfo.cs",
      "!**/*Id.cs",
      "!**/*Configuration.cs",
      "!**/*Summary.cs",
      "!**/*Group.cs",
      "!**/Program.cs",
      "!**/IApiAssemblyMarker.cs"
    ]
  }
}
