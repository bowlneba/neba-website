{
  "stryker-config": {
    "project": "Neba.Infrastructure.csproj",
    "test-runner": "mtp",
    "reporters": ["html", "json", "progress"],
    "project-info": {
      "name": "github.com/bowlneba/neba-website",
      "module": "infrastructure"
    },
    "thresholds": {
      "high": 75,
      "low": 65,
      "break": 0
    },
    "ignore-mutations": ["string", "Update", "Linq"],
    "additional-timeout": 30000,
    "ignore-methods": [
      "ArgumentNullException.ThrowIfNull",
      "ArgumentException.ThrowIfNullOrEmpty",
      "Guard.*",
      "Log.*",
      "Logger.*"
    ],
    "mutate": [
      "**/*.cs",
      "!**/AssemblyInfo.cs",
      "!**/*Configuration.cs",
      "!**/Migrations/**",
      "!**/AppDbContextModelSnapshot.cs",
      "!**/AppDbContextDesignTimeFactory.cs",
      "!**/IInfrastructureAssemblyMarker.cs"
    ]
  }
}
