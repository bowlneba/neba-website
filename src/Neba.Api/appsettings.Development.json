{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Npgsql": "Information",
      "Azure.Core": "Information",
      "Hangfire": "Information"
    }
  },

  "AllowedHosts": "localhost",

  "SlowQuery:ThresholdMs": 200,
  
  "Hangfire:WorkerCount": 1,

  "JwtSettings:Issuer": "neba-dev",
  "JwtSettings:Audience": "neba-dev",
  "JwtSettings:SigningKey": "dev-only-signing-key-at-least-32-chars!!"
}