@page "/contact"

<PageTitle>Contact · NEBA</PageTitle>
<HeadContent>
    <meta name="description"
          content="Contact the New England Bowling Association. Reach the right person for tournaments, membership, general inquiries, or website issues." />
</HeadContent>

<div class="space-y-16 py-8">
    <!-- Hero Section -->
    <section
        class="rounded-lg bg-gradient-to-br from-[#052767] via-[#2A3AA0] to-[#3E4FD9] px-8 py-16 md:px-16 md:py-20 text-white relative overflow-hidden">
        <!-- Background gradient overlay -->
        <div
            class="absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-transparent opacity-20 pointer-events-none">
        </div>

        <div class="relative z-10">
            <div class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-widest mb-4"
                 style="color: #FFD580;">
                <span
                style="width: 28px; height: 2px; background: #FFD580; border-radius: 2px; display: inline-block;"></span>
                Get in touch
            </div>

            <h1 class="text-5xl md:text-6xl font-bold mb-4 max-w-4xl"
                style="font-family: 'Manrope', sans-serif; letter-spacing: -0.025em;">
                Connect with NEBA
            </h1>

            <p class="text-lg md:text-xl max-w-3xl mb-8" style="color: rgba(255,255,255,0.78); line-height: 1.55;">
                Three departments serve the New England Bowling Association — for general questions, tournament and
                membership matters, or anything wrong on this website. No forms. Just email.
            </p>

            <div class="flex flex-col md:flex-row gap-8 md:gap-12 pt-6 border-t"
                 style="border-color: rgba(255,255,255,0.18);">
                <div>
                    <div class="text-xs font-semibold uppercase tracking-widest mb-2"
                         style="color: rgba(255,255,255,0.55);">Typical reply</div>
                    <div class="text-lg font-semibold">Within 2 business days</div>
                </div>
                <div>
                    <div class="text-xs font-semibold uppercase tracking-widest mb-2"
                         style="color: rgba(255,255,255,0.55);">Availability</div>
                    <div class="text-lg font-semibold">Weekdays & evenings</div>
                </div>
                <div>
                    <div class="text-xs font-semibold uppercase tracking-widest mb-2"
                         style="color: rgba(255,255,255,0.55);">Region</div>
                    <div class="text-lg font-semibold">New England, USA</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Cards Section -->
    <section class="space-y-4">
        <div class="space-y-2">
            <div style="width: 36px; height: 3px; background: #B8860B; border-radius: 2px;"></div>
            <h2 class="text-4xl font-bold" style="font-family: 'Manrope', sans-serif; letter-spacing: -0.015em;">Pick
                the right inbox</h2>
                <p class="text-gray-600 max-w-2xl">Each address goes to a different person. Choosing the right one gets you
                    a faster, better answer.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
                    <!-- General Inquiries Card -->
                    <div
                        class="bg-white border border-gray-200 rounded-lg p-7 hover:border-blue-300 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 relative flex flex-col">
                        <div class="absolute top-0 left-7 right-7 h-1 rounded-b" style="background: var(--neba-blue-700);">
                        </div>
                        <div class="flex items-center justify-center w-11 h-11 rounded-lg mb-5 text-xl"
                             style="background: #eef0fd; color: var(--neba-blue-700);">
                            ✉️
                        </div>
                        <div class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-1">General inquiries</div>
                        <h3 class="text-2xl font-bold mb-3"
                            style="font-family: 'Manrope', sans-serif; letter-spacing: -0.015em;">Anything else</h3>
                        <p class="text-gray-700 mb-4 text-sm">Not sure who to ask? Start here. We'll route your message to the
                            right department.</p>
                            <ul class="space-y-2 mb-6 text-sm text-gray-700">
                                <li class="flex gap-2">
                                    <span class="inline-block w-1.5 h-1.5 rounded-full mt-1.5"
                                          style="background: #CCCCCC; flex-shrink: 0;"></span>
                                    <span>Sponsorship & partnerships</span>
                                </li>
                                <li class="flex gap-2">
                                    <span class="inline-block w-1.5 h-1.5 rounded-full mt-1.5"
                                          style="background: #CCCCCC; flex-shrink: 0;"></span>
                                    <span>Press, media, and history requests</span>
                                </li>
                                <li class="flex gap-2">
                                    <span class="inline-block w-1.5 h-1.5 rounded-full mt-1.5"
                                          style="background: #CCCCCC; flex-shrink: 0;"></span>
                                    <span>General questions about NEBA</span>
                                </li>
                            </ul>
                            <a href="mailto:info@bowlneba.com"
                               class="mt-auto inline-flex items-center gap-2 bg-gray-100 hover:bg-blue-700 hover:text-white border border-gray-200 hover:border-blue-700 rounded px-4 py-2 text-sm font-semibold text-blue-700 transition-colors">
                                info@bowlneba.com
                                →
                            </a>
                        </div>

                        <!-- Tournament & Membership Card -->
                        <div
                            class="bg-white border border-gray-200 rounded-lg p-7 hover:border-yellow-300 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 relative flex flex-col">
                            <div class="absolute top-0 left-7 right-7 h-1 rounded-b" style="background: #B8860B;"></div>
                            <div class="flex items-center justify-center w-11 h-11 rounded-lg mb-5 text-xl"
                                 style="background: #fdf3d8; color: #8a6508;">
                                💼
                            </div>
                            <div class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-1">Tournaments & Membership
                            </div>
                            <h3 class="text-2xl font-bold mb-1"
                                style="font-family: 'Manrope', sans-serif; letter-spacing: -0.015em;">Tournaments & membership</h3>
                            <p class="text-gray-700 mb-4 text-sm">Managed by <strong>Dan Kaye</strong></p>
                            <ul class="space-y-2 mb-6 text-sm text-gray-700">
                                <li class="flex gap-2">
                                    <span class="inline-block w-1.5 h-1.5 rounded-full mt-1.5"
                                          style="background: #B8860B; flex-shrink: 0;"></span>
                                    <span>Tournament entries, withdrawals, refunds</span>
                                </li>
                                <li class="flex gap-2">
                                    <span class="inline-block w-1.5 h-1.5 rounded-full mt-1.5"
                                          style="background: #B8860B; flex-shrink: 0;"></span>
                                    <span>Membership status & eligibility</span>
                                </li>
                                <li class="flex gap-2">
                                    <span class="inline-block w-1.5 h-1.5 rounded-full mt-1.5"
                                          style="background: #B8860B; flex-shrink: 0;"></span>
                                    <span>Rules, scoring, and on-lane questions</span>
                                </li>
                            </ul>
                            <a href="mailto:manager@bowlneba.com"
                               class="mt-auto inline-flex items-center gap-2 bg-gray-100 hover:bg-yellow-600 hover:text-white border border-gray-200 hover:border-yellow-600 rounded px-4 py-2 text-sm font-semibold text-yellow-700 transition-colors">
                                manager@bowlneba.com
                                →
                            </a>
                        </div>

                        <!-- Website Issues Card -->
                        <div
                            class="bg-white border border-gray-200 rounded-lg p-7 hover:border-blue-200 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 relative flex flex-col">
                            <div class="absolute top-0 left-7 right-7 h-1 rounded-b"
                                 style="background: linear-gradient(90deg, #3E4FD9, #6C77E1);"></div>
                            <div class="flex items-center justify-center w-11 h-11 rounded-lg mb-5 text-xl"
                                 style="background: #eef0fd; color: var(--neba-blue-700);">
                                🔧
                            </div>
                            <div class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-1">Website issues</div>
                            <h3 class="text-2xl font-bold mb-3"
                                style="font-family: 'Manrope', sans-serif; letter-spacing: -0.015em;">Something broken here?</h3>
                            <p class="text-gray-700 mb-4 text-sm">Found a wrong score, a dead link, a typo, or a page that won't
                                load? Send it our way and we'll get it fixed.</p>
                                <ul class="space-y-2 mb-6 text-sm text-gray-700">
                                    <li class="flex gap-2">
                                        <span class="inline-block w-1.5 h-1.5 rounded-full mt-1.5"
                                              style="background: #CCCCCC; flex-shrink: 0;"></span>
                                        <span>Incorrect results or standings</span>
                                    </li>
                                    <li class="flex gap-2">
                                        <span class="inline-block w-1.5 h-1.5 rounded-full mt-1.5"
                                              style="background: #CCCCCC; flex-shrink: 0;"></span>
                                        <span>Broken links or layout problems</span>
                                    </li>
                                    <li class="flex gap-2">
                                        <span class="inline-block w-1.5 h-1.5 rounded-full mt-1.5"
                                              style="background: #CCCCCC; flex-shrink: 0;"></span>
                                        <span>Account & sign-in issues</span>
                                    </li>
                                </ul>
                                <a href="mailto:website@bowlneba.com"
                                   class="mt-auto inline-flex items-center gap-2 bg-gray-100 hover:bg-blue-700 hover:text-white border border-gray-200 hover:border-blue-700 rounded px-4 py-2 text-sm font-semibold text-blue-700 transition-colors">
                                    website@bowlneba.com
                                    →
                                </a>
                            </div>
                        </div>
                    </section>

                    <!-- Notes Section -->
                    <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="md:col-span-2 bg-white border border-gray-200 rounded-lg p-7">
                            <h3 class="text-xl font-bold mb-4" style="font-family: 'Manrope', sans-serif;">Before you email about a
                                result</h3>
                                <p class="text-gray-700 leading-relaxed">
                                    If you spot a wrong score or placement, please include the <strong>tournament name</strong>,
                                    <strong>date</strong>, and the <strong>bowler(s)</strong> involved — and a link to the page if possible.
                                    That lets us fix it in one round-trip instead of three.
                                </p>
                            </div>
                            <div class="bg-white border border-gray-200 rounded-lg p-7" style="background: #f3f5fd; border-color: #dfe4f7;">
                                <h3 class="text-xl font-bold mb-4" style="font-family: 'Manrope', sans-serif;">Quick reference</h3>
                                <dl class="space-y-3 text-sm">
                                    <div class="flex gap-3">
                                        <dt class="text-xs font-semibold uppercase tracking-widest text-gray-500 flex-shrink-0">General</dt>
                                        <dd class="text-gray-800 font-medium"><a href="mailto:info@bowlneba.com"
                                                                                     class="hover:text-blue-700">info@bowlneba.com</a></dd>
                                        </div>
                                        <div class="flex gap-3 pt-2 border-t border-blue-200">
                                            <dt class="text-xs font-semibold uppercase tracking-widest text-gray-500 flex-shrink-0">Manager</dt>
                                            <dd class="text-gray-800 font-medium"><a href="mailto:manager@bowlneba.com"
                                                                                         class="hover:text-blue-700">manager@bowlneba.com</a></dd>
                                            </div>
                                            <div class="flex gap-3 pt-2 border-t border-blue-200">
                                                <dt class="text-xs font-semibold uppercase tracking-widest text-gray-500 flex-shrink-0">Website</dt>
                                                <dd class="text-gray-800 font-medium"><a href="mailto:website@bowlneba.com"
                                                                                             class="hover:text-blue-700">website@bowlneba.com</a></dd>
                                                </div>
                                            </dl>
                                        </div>
                                    </section>

                    <!-- Socials Section -->
                    <section class="bg-white border border-gray-200 rounded-lg p-7">
                        <div class="space-y-2 mb-6">
                            <div style="width: 36px; height: 3px; background: #B8860B; border-radius: 2px;"></div>
                            <h2 class="text-2xl font-bold" style="font-family: 'Manrope', sans-serif; letter-spacing: -0.015em;">Follow NEBA</h2>
                            <p class="text-gray-600 text-sm">Stay up to date with tournaments, results, and announcements.</p>
                        </div>
                        <div class="flex flex-wrap gap-4">
                            <!-- Facebook -->
                            <a href="https://www.facebook.com/bowlNEBA/" target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center gap-3 px-5 py-3 rounded-lg border border-gray-200 hover:border-blue-600 hover:bg-blue-50 transition-all duration-200 group">
                                <svg class="w-5 h-5 flex-shrink-0" style="color: #1877F2;" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M24 12.073C24 5.406 18.627 0 12 0S0 5.406 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
                                </svg>
                                <span class="text-sm font-semibold text-gray-700 group-hover:text-blue-700">Facebook</span>
                            </a>
                            <!-- Instagram -->
                            <a href="https://www.instagram.com/bowlneba" target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center gap-3 px-5 py-3 rounded-lg border border-gray-200 hover:border-pink-500 hover:bg-pink-50 transition-all duration-200 group">
                                <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <defs>
                                        <linearGradient id="ig-grad" x1="0%" y1="100%" x2="100%" y2="0%">
                                            <stop offset="0%" stop-color="#F58529"/>
                                            <stop offset="30%" stop-color="#DD2A7B"/>
                                            <stop offset="65%" stop-color="#8134AF"/>
                                            <stop offset="100%" stop-color="#515BD4"/>
                                        </linearGradient>
                                    </defs>
                                    <rect width="24" height="24" rx="6" fill="url(#ig-grad)"/>
                                    <circle cx="12" cy="12" r="4" stroke="white" stroke-width="1.8" fill="none"/>
                                    <circle cx="17.5" cy="6.5" r="1.1" fill="white"/>
                                </svg>
                                <span class="text-sm font-semibold text-gray-700 group-hover:text-pink-600">Instagram</span>
                            </a>
                            <!-- YouTube -->
                            <a href="https://www.youtube.com/bowlneba" target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center gap-3 px-5 py-3 rounded-lg border border-gray-200 hover:border-red-500 hover:bg-red-50 transition-all duration-200 group">
                                <svg class="w-5 h-5 flex-shrink-0" style="color: #FF0000;" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
                                </svg>
                                <span class="text-sm font-semibold text-gray-700 group-hover:text-red-600">YouTube</span>
                            </a>
                            <!-- Discord -->
                            <a href="https://discord.gg/QVKrrzuvyK" target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center gap-3 px-5 py-3 rounded-lg border border-gray-200 hover:border-indigo-500 hover:bg-indigo-50 transition-all duration-200 group">
                                <svg class="w-5 h-5 flex-shrink-0" style="color: #5865F2;" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                                </svg>
                                <span class="text-sm font-semibold text-gray-700 group-hover:text-indigo-600">Discord</span>
                            </a>
                        </div>
                    </section>
                                </div>
