@page "/tournaments"
@namespace Neba.Website.Server.Tournaments.Schedule
@implements IAsyncDisposable
@inject ITournamentDataService DataService
@inject NavigationManager Nav

@rendermode @(new InteractiveServerRenderMode(prerender: false))
@preservewhitespace false

<PageTitle>Tournaments - NEBA</PageTitle>
<HeadContent>
    <meta name="description"
          content="NEBA tournament schedule – upcoming and past scratch bowling tournaments in New England." />
</HeadContent>

<div class="tournaments-page">
    <div class="tournaments-content">

        @if (ShowHero)
        {
            <TournamentHero Tournament="@(HeroTournament!)" />
        }
        else
        {
            <header class="tournaments-page__header">
                <p class="tournaments-page__eyebrow">@_activeSeason?.Description</p>
                <h1 class="tournaments-page__title">Tournaments</h1>
            </header>
        }

        @if (_allTournaments is not null)
        {
            <SeasonTimeline Tournaments="@_allTournaments" Season="@(_activeSeason?.Label ?? string.Empty)" />
        }

        <TournamentTabBar ActiveTab="@_activeTab" IsCurrentSeason="@_isCurrentSeason"
                          AvailableSeasons="@(_availableSeasons ?? [])" ActiveSeason="@_activeSeason" OnTabChanged="HandleTabChanged"
                          OnSeasonChanged="HandleSeasonChanged" />

        <TournamentFilterBar SearchTerm="@_searchTerm" SearchTermChanged="@(v => _searchTerm = v)"
                             TypeFilter="@_typeFilter" TypeFilterChanged="@(v => _typeFilter = v)"
                             EligibilityFilter="@_eligibilityFilter" EligibilityFilterChanged="@(v => _eligibilityFilter = v)" />

        @if (_isLoading)
        {
            <TournamentListSkeleton ShowHeroSkeleton="@ShowHero" />
        }
        else
        {
            <div class="tournaments-page__list" id="tournament-list" role="list" aria-live="polite"
                 aria-label="@($"{FilteredTournaments.Count()} tournaments")">

                @foreach (var t in FilteredTournaments)
                {
                    @if (_activeTab == TournamentTab.Upcoming)
                    {
                        <TournamentUpcomingCard Tournament="@t" />
                    }
                    else
                    {
                        <TournamentPastCard Tournament="@t" />
                    }
                }

                @if (!FilteredTournaments.Any())
                {
                    <TournamentEmptyState Tab="@_activeTab" HasActiveFilters="@HasActiveFilters"
                                          OnClearFilters="ClearFilters" />
                }
            </div>

            @if (_isMergedSeason)
            {
                <MergedSeasonNote />
            }
        }

    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "year")]
    public int? Year { get; set; }

    // ── Route-driven state ─────────────────────────────────────────────────
    private SeasonViewModel? _activeSeason;
    private bool _isCurrentSeason = true;
    private bool _isMergedSeason;

    // ── UI state ───────────────────────────────────────────────────────────
    private TournamentTab _activeTab = TournamentTab.Upcoming;

    // ── Filter state ───────────────────────────────────────────────────────
    private string _searchTerm = string.Empty;
    private TournamentType? _typeFilter;
    private TournamentEligibility? _eligibilityFilter;

    // ── Data ───────────────────────────────────────────────────────────────
    private List<TournamentSummaryViewModel>? _allTournaments;
    private List<SeasonViewModel>? _availableSeasons;
    private TournamentSummaryViewModel? _nextSeasonHeroTournament;
    private bool _isLoading = true;

    private CancellationTokenSource _cts = new();
    private bool _disposed;

    // ── Computed ───────────────────────────────────────────────────────────
    private TournamentSummaryViewModel? NextUpcomingTournament =>
        _allTournaments?
            .Where(t => !t.IsPast)
            .OrderBy(t => t.StartDate)
            .FirstOrDefault();

    private TournamentSummaryViewModel? HeroTournament =>
        NextUpcomingTournament ?? _nextSeasonHeroTournament;

    private bool ShowHero =>
        _isCurrentSeason &&
        _activeTab == TournamentTab.Upcoming &&
        HeroTournament is not null;

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_searchTerm) ||
        _typeFilter.HasValue ||
        _eligibilityFilter.HasValue;

    private IEnumerable<TournamentSummaryViewModel> FilteredTournaments
    {
        get
        {
            if (_allTournaments is null)
            {
                return [];
            }

            var query = _allTournaments
                .Where(t => _activeTab == TournamentTab.Upcoming ? !t.IsPast : t.IsPast);

            if (!string.IsNullOrWhiteSpace(_searchTerm))
            {
                query = query.Where(t =>
                    t.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    (t.BowlingCenterName?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (t.Sponsor?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            if (_typeFilter.HasValue)
            {
                query = query.Where(t => t.TournamentType == _typeFilter);
            }

            if (_eligibilityFilter.HasValue)
            {
                query = query.Where(t => t.Eligibility == _eligibilityFilter);
            }

            return query.OrderBy(t => t.StartDate);
        }
    }

    // ── Lifecycle ──────────────────────────────────────────────────────────
    protected override async Task OnParametersSetAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
        _cts = new CancellationTokenSource();
        var ct = _cts.Token;

        _isLoading = true;
        _allTournaments = null;

        try
        {
            // Resolve available seasons (cached after first load)
            _availableSeasons ??= await DataService.GetSeasonsAsync(ct);

            var today = DateTime.Today;
            var requestedYear = Year ?? today.Year;

            var matched = _availableSeasons.FirstOrDefault(s => s.ContainsYear(requestedYear));
            var current = _availableSeasons.FirstOrDefault(s => s.ContainsYear(today.Year));

            if (matched is null)
            {
                Nav.NavigateTo("/tournaments");
                return;
            }

            _activeSeason = matched;
            _isCurrentSeason = matched == current;
            _isMergedSeason = matched.IsMergedSeason;
            _activeTab = _isCurrentSeason ? TournamentTab.Upcoming : TournamentTab.Past;

            _searchTerm = string.Empty;
            _typeFilter = null;
            _eligibilityFilter = null;
            _nextSeasonHeroTournament = null;

            _allTournaments = await DataService.GetTournamentsForSeasonAsync(_activeSeason, ct);

            // When the current season has no upcoming tournaments, look ahead to the
            // next season so the hero can surface the first scheduled tournament.
            if (_isCurrentSeason && _allTournaments.TrueForAll(t => t.IsPast))
            {
                var nextSeason = _availableSeasons
                    .Where(s => s.StartDate > _activeSeason.EndDate)
                    .OrderBy(s => s.StartDate)
                    .FirstOrDefault();

                if (nextSeason is not null)
                {
                    var nextTournaments = await DataService.GetTournamentsForSeasonAsync(nextSeason, ct);
                    _nextSeasonHeroTournament = nextTournaments
                        .Where(t => !t.IsPast)
                        .OrderBy(t => t.StartDate)
                        .FirstOrDefault();
                }
            }
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
            return;
        }

        if (ct.IsCancellationRequested || _disposed)
        {
            return;
        }

        _isLoading = false;
    }

    // ── Handlers ───────────────────────────────────────────────────────────
    private void HandleTabChanged(TournamentTab tab)
    {
        if (tab == TournamentTab.Upcoming && !_isCurrentSeason)
        {
            return;
        }

        _activeTab = tab;
        _searchTerm = string.Empty;
    }

    private void HandleSeasonChanged(int year)
    {
        Nav.NavigateTo(year == DateTime.Today.Year ? "/tournaments" : $"/tournaments?year={year}");
    }

    private void ClearFilters()
    {
        _searchTerm = string.Empty;
        _typeFilter = null;
        _eligibilityFilter = null;
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        await _cts.CancelAsync();
        _cts.Dispose();
    }
}
