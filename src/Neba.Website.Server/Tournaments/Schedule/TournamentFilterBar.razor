@namespace Neba.Website.Server.Tournaments.Schedule

<div class="tournament-filter-bar">
    <div class="tournament-filter-bar__search-wrapper">
        <span class="material-symbols-outlined tournament-filter-bar__search-icon" aria-hidden="true">search</span>
        <input type="search"
               class="neba-input tournament-filter-bar__search"
               placeholder="Search tournaments…"
               value="@SearchTerm"
               @oninput="e => SearchTermChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty)"
               aria-label="Search tournaments" />
    </div>

    <div class="neba-segmented-control tournament-filter-bar__type-filter" aria-label="Filter by format">
        <button class="neba-segment-button @(TypeFilter == null ? "neba-segment-selected" : "")"
                @onclick="() => TypeFilterChanged.InvokeAsync(null)">All</button>
        <button class="neba-segment-button @(TypeFilter == TournamentType.Singles ? "neba-segment-selected" : "")"
                @onclick="() => TypeFilterChanged.InvokeAsync(TournamentType.Singles)">Singles</button>
        <button class="neba-segment-button @(TypeFilter == TournamentType.Doubles ? "neba-segment-selected" : "")"
                @onclick="() => TypeFilterChanged.InvokeAsync(TournamentType.Doubles)">Doubles</button>
        <button class="neba-segment-button @(TypeFilter == TournamentType.Trios ? "neba-segment-selected" : "")"
                @onclick="() => TypeFilterChanged.InvokeAsync(TournamentType.Trios)">Trios</button>
    </div>

</div>

@code {
    [Parameter, EditorRequired]
    public string SearchTerm { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public EventCallback<string> SearchTermChanged { get; set; }

    [Parameter]
    public TournamentType? TypeFilter { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<TournamentType?> TypeFilterChanged { get; set; }

}
