@namespace Neba.Website.Server.Tournaments.Schedule

<div class="tournament-logo-tile tournament-logo-tile--@Variant.ToString().ToLowerInvariant() @CssClass" role="img"
     aria-label="@TournamentName – @TournamentType tournament">
    <span class="tournament-logo-tile__logo-mark" aria-hidden="true">NEBA</span>
    <span class="tournament-logo-tile__type" aria-hidden="true">@TournamentType.ToUpperInvariant()</span>
    <span class="tournament-logo-tile__year" aria-hidden="true">@Season</span>
</div>

@code {
    [Parameter, EditorRequired]
    public string TournamentType { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Season { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string TournamentName { get; set; } = string.Empty;

    [Parameter]
    public LogoTileVariant Variant { get; set; } = LogoTileVariant.Default;

    [Parameter]
    public string? CssClass { get; set; }
}
