@code {
    [SupplyParameterFromQuery(Name = "season")]
    public int? Season { get; set; }

    private StatsPageViewModel? _model;
    private bool _isLoading = true;
    private bool _loadError;
    private string _activeTab = "award-standings";
    private int _selectedSeasonYear;
    private IReadOnlyDictionary<int, string> _initialAvailableSeasons = new Dictionary<int, string>();
    private string _bowlerSearchText = "";

    private bool _modalOpen;
    private string _modalTitle = "";
    private RenderFragment _modalContent = builder => { };
    private bool _modalWide;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _model = await StatsApi.GetStatsAsync(Season);
            _initialAvailableSeasons = _model.AvailableSeasons;

            if (_initialAvailableSeasons.Count == 0)
            {
                _loadError = true;
                return;
            }

            _selectedSeasonYear = ResolveSelectedSeasonYear(_model, Season);
        }
        catch (Exception ex)
        {
            Logger.LogFailedToLoadSeasonStats(ex);
            _loadError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnSeasonChanged(int year)
    {
        _isLoading = true;
        _loadError = false;
        _selectedSeasonYear = year;
        CloseModal();
        StateHasChanged();

        try
        {
            _model = await StatsApi.GetStatsAsync(year);
            SetStatsPageSeasonQuery(year);
        }
        catch (Exception ex)
        {
            Logger.LogFailedToLoadSeasonStatsForYear(ex, year);
            _loadError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void SetActiveTab(string tab) => _activeTab = tab;

    private string TabClass(string tab)
        => _activeTab == tab ? "stats-tab stats-tab-active" : "stats-tab";

    private string PanelClass(string tab)
        => _activeTab == tab ? "tab-panel" : "tab-panel tab-hidden";

    private void OnBowlerSearchInput(ChangeEventArgs e)
        => _bowlerSearchText = e.Value?.ToString() ?? "";

    private void OnBowlerSearchChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(value) || _model is null) return;
        var match = _model.BowlerSearchList
            .FirstOrDefault(kvp => kvp.Value.Equals(value, StringComparison.OrdinalIgnoreCase));
        if (match.Key != null)
            Nav.NavigateTo(GetIndividualStatsUrl(match.Key));
    }

    private static int ResolveSelectedSeasonYear(StatsPageViewModel model, int? requestedSeason)
    {
        if (requestedSeason.HasValue && model.AvailableSeasons.ContainsKey(requestedSeason.Value))
        {
            return requestedSeason.Value;
        }

        var selectedSeason = model.AvailableSeasons
            .FirstOrDefault(season => season.Value == model.SelectedSeason);

        return selectedSeason.Key != 0
            ? selectedSeason.Key
            : model.AvailableSeasons.Keys.First();
    }

    private string GetIndividualStatsUrl(string bowlerId)
        => _selectedSeasonYear > 0
            ? $"/stats/{bowlerId}?season={_selectedSeasonYear}"
            : $"/stats/{bowlerId}";

    private void SetStatsPageSeasonQuery(int year)
    {
        var uri = Nav.GetUriWithQueryParameter("season", year);
        Nav.NavigateTo(uri, replace: true);
    }

    private IEnumerable<KeyValuePair<string, string>> FilteredBowlers()
    {
        if (_model is null) return [];
        if (string.IsNullOrWhiteSpace(_bowlerSearchText))
            return _model.BowlerSearchList.Take(20);
        return _model.BowlerSearchList
            .Where(kvp => kvp.Value.Contains(_bowlerSearchText, StringComparison.OrdinalIgnoreCase))
            .Take(20);
    }

    private IEnumerable<(string Title, IReadOnlyCollection<BowlerOfTheYearStandingRowViewModel> Rows, int DisplayCount, IReadOnlyCollection<PointsRaceSeriesViewModel> Series)>
BoyStandingsSections()
    {
        if (_model is null) yield break;
        yield return ("Bowler of the Year",       _model.BowlerOfTheYear,       20, _model.OpenPointsRace);
        yield return ("Senior of the Year",       _model.SeniorOfTheYear,       10, _model.SeniorPointsRace);
        yield return ("Super Senior of the Year", _model.SuperSeniorOfTheYear,  10, _model.SuperSeniorPointsRace);
        yield return ("Woman of the Year",        _model.WomanOfTheYear,        10, _model.WomenPointsRace);
        yield return ("Rookie of the Year",       _model.RookieOfTheYear,       10, _model.RookiePointsRace);
        yield return ("Youth of the Year",        _model.YouthOfTheYear,        10, _model.YouthPointsRace);
    }

    private void OpenBoyModal(string title, IReadOnlyCollection<BowlerOfTheYearStandingRowViewModel> rows)
    {
        OpenStandingsModal(title, RenderBoyStandingsTable(rows));
    }

    private void OpenHighAverageModal()
    {
        if (_model is null)
        {
            return;
        }

        OpenStandingsModal("High Average", RenderHighAverageTable(_model.HighAverage));
    }

    private void OpenHighBlockModal()
    {
        if (_model is null)
        {
            return;
        }

        OpenStandingsModal("High Block", RenderHighBlockTable(_model.HighBlock));
    }

    private void OpenMatchPlayAverageModal()
    {
        if (_model is null)
        {
            return;
        }

        OpenStandingsModal("Match Play Average", RenderMatchPlayAverageTable(_model.MatchPlayAverage));
    }

