    private static RenderFragment RenderProgressionModal(IReadOnlyCollection<PointsRaceSeriesViewModel> series)
    {
        var top10 = series
            .OrderByDescending(s => s.Results.LastOrDefault()?.CumulativePoints ?? 0)
            .Take(10)
            .ToArray();

        if (top10.Length > 0)
        {
            return @<div class="stats-chart-modal">
                <PointsRaceChart Series="@top10" Title="" ShowCategoryLabels="true" Height="520" />
            </div>;
        }

        return @<div class="stats-chart-modal">
            <p class="text-gray-500 text-sm">No data available for this race yet.</p>
        </div>;
    }

    private static string FormatFieldAvg(decimal value)
        => value >= 0 ? $"+{value:F2}" : value.ToString("F2");

    private static string FormatWinPercentage(decimal? value)
        => value.HasValue ? $"{value.Value:F1}%" : "—";

    private static string FieldAvgClass(decimal value)
        => value >= 0 ? "text-[var(--neba-success)]" : "text-gray-400";

    private static string FieldAvgAriaLabel(decimal value)
        => value >= 0
            ? $"{Math.Abs(value):F2} above field average"
            : $"{Math.Abs(value):F2} below field average";
}
