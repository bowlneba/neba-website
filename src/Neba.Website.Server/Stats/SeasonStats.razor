@page "/stats"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IStatsApiService StatsApi
@inject NavigationManager Nav
@inject ILogger<SeasonStats> Logger

<PageTitle>Season Stats - NEBA</PageTitle>
<HeadContent>
    <meta name="description"
          content="NEBA season bowling statistics including award standings, averages, match play records, and efficiency rankings." />
</HeadContent>

<div class="neba-content-wrapper">

    <!-- ── Hero ────────────────────────────────────────────── -->
    <div class="stats-hero">
        <h1 class="text-3xl font-bold text-[var(--neba-blue-700)]">Season Statistics</h1>
        <div class="stats-hero-controls">
            <div class="stats-season-selector" role="group" aria-label="Select season">
                @foreach (var (id, name) in _initialAvailableSeasons)
                {
                    <button class="@(id == _selectedSeasonYear ? "stats-season-btn active" : "stats-season-btn")"
                            aria-pressed="@(id == _selectedSeasonYear ? "true" : "false")" @onclick="() => OnSeasonChanged(id)">
                        @name
                    </button>
                }
            </div>
            <div class="stats-bowler-search">
                <input type="text" @oninput="OnBowlerSearchInput" @onchange="OnBowlerSearchChanged"
                       value="@_bowlerSearchText" list="bowler-search-list" placeholder="Search bowlers..."
                       class="stats-search-input" aria-label="Search for a bowler" />
                <datalist id="bowler-search-list">
                    @foreach (var (_, name) in FilteredBowlers())
                    {
                        <option value="@name" />
                    }
                </datalist>
            </div>
        </div>
    </div>

    <!-- ── Tab navigation (always rendered) ──────────────── -->
    <div role="tablist" class="stats-tabs" aria-label="Stats categories">
        <button role="tab" id="tab-award-standings"
                aria-selected="@(_activeTab == "award-standings" ? "true" : "false")" aria-controls="panel-award-standings"
                class="@TabClass("award-standings")" @onclick='() => SetActiveTab("award-standings")'>
            Award Standings
        </button>
        <button role="tab" id="tab-qualifying"
                aria-selected="@(_activeTab == "qualifying" ? "true" : "false")"
                aria-controls="panel-qualifying" class="@TabClass("qualifying")"
                @onclick='() => SetActiveTab("qualifying")'>
            Qualifying
        </button>
        <button role="tab" id="tab-match-play" aria-selected="@(_activeTab == "match-play" ? "true" : "false")"
                aria-controls="panel-match-play" class="@TabClass("match-play")"
                @onclick='() => SetActiveTab("match-play")'>
            Match Play
        </button>
        <button role="tab" id="tab-efficiency" aria-selected="@(_activeTab == "efficiency" ? "true" : "false")"
                aria-controls="panel-efficiency" class="@TabClass("efficiency")"
                @onclick='() => SetActiveTab("efficiency")'>
            Efficiency
        </button>
    </div>

    <!-- ── Two-column layout ──────────────────────────────── -->
    <div class="stats-layout">

        <main class="stats-main">
            @if (_isLoading)
            {
                <NebaSkeletonLoader Type="SkeletonType.Custom" Width="100%" Height="500px" />
            }
            else if (_loadError)
            {
                <div class="stats-loading" role="alert" aria-live="assertive">
                    Unable to load season stats right now.
                </div>
            }
            else if (_model is not null)
            {
                <!-- ── Award Standings ─────────────────────────────── -->
                <div id="panel-award-standings" role="tabpanel" aria-labelledby="tab-award-standings"
                     class="@PanelClass("award-standings") neba-space-y-6">
                    @foreach (var (title, rows, displayCount, raceSeries) in BoyStandingsSections())
                    {
                        <section class="stats-section">
                            <div class="stats-section-header stats-accent-blue-500">
                                <h2 class="stats-section-title">@title</h2>
                                <button class="stats-text-link" @onclick="() => OpenProgressionModal(raceSeries)"
                                        aria-label="@($"Open {title} points progression chart")">
                                    Points Progression
                                </button>
                            </div>
                            <div class="stats-table-wrapper">
                                <table class="stats-table">
                                    <thead>
                                        <tr>
                                            <th scope="col">Rank</th>
                                            <th scope="col">Name</th>
                                            <th scope="col" class="text-right">Points</th>
                                            <th scope="col" class="text-right">Tournaments</th>
                                            <th scope="col" class="text-right">Entries</th>
                                            <th scope="col" class="text-right">Finals</th>
                                            <th scope="col" class="text-right">Avg Finish</th>
                                            <th scope="col" class="text-right">$ Won</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in rows.Take(displayCount))
                                        {
                                            <tr class="@(row.Rank == 1 ? "stats-row-first" : "stats-row")">
                                                <td class="@(row.Rank == 1 ? "rank-cell rank-cell-accent-blue-500" : "rank-cell")">
                                                    @row.Rank</td>
                                                    <td><a href="@GetIndividualStatsUrl(row.BowlerId)" class="stats-name-link">@row.BowlerName</a></td>
                                                    <td class="text-right tabular-nums">@row.Points</td>
                                                    <td class="text-right tabular-nums">@row.Tournaments</td>
                                                    <td class="text-right tabular-nums">@row.Entries</td>
                                                    <td class="text-right tabular-nums">@row.Finals</td>
                                                    <td class="text-right tabular-nums">@(row.AverageFinish?.ToString("F1") ?? "—")</td>
                                                    <td class="text-right tabular-nums" aria-label="@($"Winnings: {row.Winnings:C0}")">
                                                        @row.Winnings.ToString("C0")</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                    @if (rows.Count > displayCount)
                                    {
                                        <button class="stats-expand-btn" aria-label="@($"Show all {rows.Count} {title} standings")"
                                                @onclick="() => OpenBoyModal(title, rows)">
                                            Show all @rows.Count
                                        </button>
                                    }
                                </section>
                            }
                        </div>

                        <!-- ── Qualifying ──────────────────────────── -->
                        <div id="panel-qualifying" role="tabpanel" aria-labelledby="tab-qualifying"
                             class="@PanelClass("qualifying") neba-space-y-6">

                            <section class="stats-section">
                                <div class="stats-section-header stats-accent-primary">
                                    <h2 class="stats-section-title">High Average</h2>
                                    @if (_model.MinimumNumberOfGames > 0)
                                    {
                                        <span class="stats-section-qualifier">min @((int)_model.MinimumNumberOfGames) games</span>
                                    }
                                </div>
                                <div class="stats-table-wrapper">
                                    <table class="stats-table">
                                        <thead>
                                            <tr>
                                                <th scope="col">Rank</th>
                                                <th scope="col">Name</th>
                                                <th scope="col" class="text-right">Average</th>
                                                <th scope="col" class="text-right">Games</th>
                                                <th scope="col" class="text-right">Tournaments</th>
                                                <th scope="col" class="text-right">vs. Field</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in _model.HighAverage.Take(10))
                                            {
                                                <tr class="@(row.Rank == 1 ? "stats-row-first" : "stats-row")">
                                                    <td class="@(row.Rank == 1 ? "rank-cell rank-cell-accent-primary" : "rank-cell")">
                                                        @row.Rank</td>
                                                        <td><a href="@GetIndividualStatsUrl(row.BowlerId)" class="stats-name-link">@row.BowlerName</a></td>
                                                        <td
                                                            class="text-right tabular-nums @(row.Rank == 1 ? "text-[var(--neba-color-primary)]" : "")">
                                                            @row.Average.ToString("F2")
                                                        </td>
                                                        <td class="text-right tabular-nums">@row.Games</td>
                                                        <td class="text-right tabular-nums">@row.Tournaments</td>
                                                        <td class="text-right tabular-nums @FieldAvgClass(row.FieldAverage)"
                                                            aria-label="@FieldAvgAriaLabel(row.FieldAverage)">
                                                            @FormatFieldAvg(row.FieldAverage)
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                    @if (_model.HighAverage.Count > 10)
                                    {
                                        <button class="stats-expand-btn" aria-label="@($"Show all {_model.HighAverage.Count} High Average standings")"
                                                @onclick="OpenHighAverageModal">
                                            Show all @_model.HighAverage.Count
                                        </button>
                                    }
                                </section>

                                <section class="stats-section">
                                    <div class="stats-section-header stats-accent-primary">
                                        <h2 class="stats-section-title">High Block</h2>
                                    </div>
                                    <div class="stats-table-wrapper">
                                        <table class="stats-table">
                                            <thead>
                                                <tr>
                                                    <th scope="col">Rank</th>
                                                    <th scope="col">Name</th>
                                                    <th scope="col" class="text-right">High Block</th>
                                                    <th scope="col" class="text-right">High Game</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var row in _model.HighBlock.Take(10))
                                                {
                                                    <tr class="@(row.Rank == 1 ? "stats-row-first" : "stats-row")">
                                                        <td class="@(row.Rank == 1 ? "rank-cell rank-cell-accent-primary" : "rank-cell")">
                                                            @row.Rank</td>
                                                            <td><a href="@GetIndividualStatsUrl(row.BowlerId)" class="stats-name-link">@row.BowlerName</a></td>
                                                            <td
                                                                class="text-right tabular-nums @(row.Rank == 1 ? "text-[var(--neba-color-primary)]" : "")">
                                                                @row.HighBlock</td>
                                                                <td class="text-right tabular-nums">@row.HighGame</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                            @if (_model.HighBlock.Count > 10)
                                            {
                                                <button class="stats-expand-btn" aria-label="@($"Show all {_model.HighBlock.Count} High Block standings")"
                                                        @onclick="OpenHighBlockModal">
                                                    Show all @_model.HighBlock.Count
                                                </button>
                                            }
                                        </section>
                                    </div>

                                            <!-- ── Match Play ──────────────────────────────────── -->
                                            <div id="panel-match-play" role="tabpanel" aria-labelledby="tab-match-play"
                                                 class="@PanelClass("match-play") neba-space-y-6">

                                                <section class="stats-section">
                                                    <div class="stats-section-header stats-accent-red">
                                                        <h2 class="stats-section-title">Match Play Record</h2>
                                                        @if (_model.MinimumNumberOfTournaments > 0)
                                                        {
                                                            <span class="stats-section-qualifier">min @((int)(_model.MinimumNumberOfTournaments * 2m)) games</span>
                                                        }
                                                    </div>
                                                    <div class="stats-table-wrapper">
                                                        <table class="stats-table">
                                                            <thead>
                                                                <tr>
                                                                    <th scope="col">Rank</th>
                                                                    <th scope="col">Name</th>
                                                                    <th scope="col" class="text-right">Record</th>
                                                                    <th scope="col" class="text-right">Win %</th>
                                                                    <th scope="col" class="text-right">Finals</th>
                                                                    <th scope="col" class="text-right">MP Avg</th>
                                                                    <th scope="col" class="text-right">$ Won</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var row in _model.MatchPlayRecord.Take(10))
                                                                {
                                                                    <tr class="@(row.Rank == 1 ? "stats-row-first" : "stats-row")">
                                                                        <td class="@(row.Rank == 1 ? "rank-cell rank-cell-accent-red" : "rank-cell")">
                                                                            @row.Rank</td>
                                                                            <td><a href="@GetIndividualStatsUrl(row.BowlerId)" class="stats-name-link">@row.BowlerName</a></td>
                                                                            <td
                                                                                class="text-right tabular-nums @(row.Rank == 1 ? "text-[var(--neba-color-error)]" : "")">
                                                                                @($"{row.Wins}–{row.Loses}")
                                                                            </td>
                                                                            <td class="text-right tabular-nums">@FormatWinPercentage(row.WinPercentage)</td>
                                                                            <td class="text-right tabular-nums">@row.Finals</td>
                                                                            <td class="text-right tabular-nums">@row.MatchPlayAverage.ToString("F2")</td>
                                                                            <td class="text-right tabular-nums" aria-label="@($"Winnings: {row.Winnings:C0}")">
                                                                                @row.Winnings.ToString("C0")</td>
                                                                            </tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                            @if (_model.MatchPlayRecord.Count > 10)
                                                            {
                                                                <button class="stats-expand-btn"
                                                                        aria-label="@($"Show all {_model.MatchPlayRecord.Count} Match Play Record standings")"
                                                                        @onclick="OpenMatchPlayRecordModal">
                                                                    Show all @_model.MatchPlayRecord.Count
                                                                </button>
                                                            }
                                                        </section>

                                                        <section class="stats-section">
                                                            <div class="stats-section-header stats-accent-red">
                                                                <h2 class="stats-section-title">Match Play Appearances</h2>
                                                            </div>
                                                            <div class="stats-table-wrapper">
                                                                <table class="stats-table">
                                                                    <thead>
                                                                        <tr>
                                                                            <th scope="col">Rank</th>
                                                                            <th scope="col">Name</th>
                                                                            <th scope="col" class="text-right">Finals</th>
                                                                            <th scope="col" class="text-right">Tournaments</th>
                                                                            <th scope="col" class="text-right">Entries</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        @foreach (var row in _model.MatchPlayAppearances.Take(10))
                                                                        {
                                                                            <tr class="@(row.Rank == 1 ? "stats-row-first" : "stats-row")">
                                                                                <td class="@(row.Rank == 1 ? "rank-cell rank-cell-accent-red" : "rank-cell")">
                                                                                    @row.Rank</td>
                                                                                    <td><a href="@GetIndividualStatsUrl(row.BowlerId)" class="stats-name-link">@row.BowlerName</a></td>
                                                                                    <td
                                                                                        class="text-right tabular-nums @(row.Rank == 1 ? "text-[var(--neba-color-error)]" : "")">
                                                                                        @row.Finals</td>
                                                                                        <td class="text-right tabular-nums">@row.Tournaments</td>
                                                                                        <td class="text-right tabular-nums">@row.Entries</td>
                                                                                    </tr>
                                                                                }
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                    @if (_model.MatchPlayAppearances.Count > 10)
                                                                    {
                                                                        <button class="stats-expand-btn"
                                                                                aria-label="@($"Show all {_model.MatchPlayAppearances.Count} Match Play Appearances standings")"
                                                                                @onclick="OpenMatchPlayAppearancesModal">
                                                                            Show all @_model.MatchPlayAppearances.Count
                                                                        </button>
                                                                    }
                                                                </section>

                                                                <section class="stats-section">
                                                                    <div class="stats-section-header stats-accent-red">
                                                                        <h2 class="stats-section-title">Match Play Average</h2>
                                                                        @if (_model.MinimumNumberOfTournaments > 0)
                                                                        {
                                                                            <span class="stats-section-qualifier">min @((int)(_model.MinimumNumberOfTournaments * 2m)) games</span>
                                                                        }
                                                                    </div>
                                                                    <div class="stats-table-wrapper">
                                                                        <table class="stats-table">
                                                                            <thead>
                                                                                <tr>
                                                                                    <th scope="col">Rank</th>
                                                                                    <th scope="col">Name</th>
                                                                                    <th scope="col" class="text-right">MP Avg</th>
                                                                                    <th scope="col" class="text-right">Games</th>
                                                                                    <th scope="col" class="text-right">Record</th>
                                                                                    <th scope="col" class="text-right">Win %</th>
                                                                                    <th scope="col" class="text-right">$ Won</th>
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                @foreach (var row in _model.MatchPlayAverage.Take(10))
                                                                                {
                                                                                    <tr class="@(row.Rank == 1 ? "stats-row-first" : "stats-row")">
                                                                                        <td class="@(row.Rank == 1 ? "rank-cell rank-cell-accent-red" : "rank-cell")">
                                                                                            @row.Rank</td>
                                                                                            <td><a href="@GetIndividualStatsUrl(row.BowlerId)" class="stats-name-link">@row.BowlerName</a></td>
                                                                                            <td
                                                                                                class="text-right tabular-nums @(row.Rank == 1 ? "text-[var(--neba-color-error)]" : "")">
                                                                                                @row.MatchPlayAverage.ToString("F2")
                                                                                            </td>
                                                                                            <td class="text-right tabular-nums">@row.Games</td>
                                                                                            <td class="text-right tabular-nums">@($"{row.Wins}–{row.Loses}")</td>
                                                                                            <td class="text-right tabular-nums">
                                                                                                @FormatWinPercentage(row.WinPercentage)
                                                                                            </td>
                                                                                            <td class="text-right tabular-nums" aria-label="@($"Winnings: {row.Winnings:C0}")">
                                                                                                @row.Winnings.ToString("C0")</td>
                                                                                            </tr>
                                                                                        }
                                                                                    </tbody>
                                                                                </table>
                                                                            </div>
                                                                            @if (_model.MatchPlayAverage.Count > 10)
                                                                            {
                                                                                <button class="stats-expand-btn"
                                                                                        aria-label="@($"Show all {_model.MatchPlayAverage.Count} Match Play Average standings")"
                                                                                        @onclick="OpenMatchPlayAverageModal">
                                                                                    Show all @_model.MatchPlayAverage.Count
                                                                                </button>
                                                                            }
                                                                        </section>
                                                                    </div>

                                                            <!-- ── Efficiency ──────────────────────────────────── -->
                                                            <div id="panel-efficiency" role="tabpanel" aria-labelledby="tab-efficiency"
                                                                 class="@PanelClass("efficiency") neba-space-y-6">

                                                                <section class="stats-section">
                                                                    <div class="stats-section-header stats-accent-blue-300">
                                                                        <h2 class="stats-section-title">Points Per Entry</h2>
                                                                        @if (_model.MinimumNumberOfEntries > 0)
                                                                        {
                                                                            <span class="stats-section-qualifier">min @(_model.MinimumNumberOfEntries.ToString("F1")) entries</span>
                                                                        }
                                                                    </div>
                                                                    <div class="stats-table-wrapper">
                                                                        <table class="stats-table">
                                                                            <thead>
                                                                                <tr>
                                                                                    <th scope="col">Rank</th>
                                                                                    <th scope="col">Name</th>
                                                                                    <th scope="col" class="text-right">Pts / Entry</th>
                                                                                    <th scope="col" class="text-right">Total Points</th>
                                                                                    <th scope="col" class="text-right">Entries</th>
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                @foreach (var row in _model.PointsPerEntry.Take(10))
                                                                                {
                                                                                    <tr class="@(row.Rank == 1 ? "stats-row-first" : "stats-row")">
                                                                                        <td class="@(row.Rank == 1 ? "rank-cell rank-cell-accent-blue-300" : "rank-cell")">
                                                                                            @row.Rank</td>
                                                                                            <td><a href="@GetIndividualStatsUrl(row.BowlerId)" class="stats-name-link">@row.BowlerName</a></td>
                                                                                            <td
                                                                                                class="text-right tabular-nums @(row.Rank == 1 ? "text-[var(--neba-blue-300)]" : "")">
                                                                                                @row.PointsPerEntry.ToString("F3")
                                                                                            </td>
                                                                                            <td class="text-right tabular-nums">@row.Points</td>
                                                                                            <td class="text-right tabular-nums">@row.Entries</td>
                                                                                        </tr>
                                                                                    }
                                                                                </tbody>
                                                                            </table>
                                                                        </div>
                                                                        @if (_model.PointsPerEntry.Count > 10)
                                                                        {
                                                                            <button class="stats-expand-btn"
                                                                                    aria-label="@($"Show all {_model.PointsPerEntry.Count} Points Per Entry standings")"
                                                                                    @onclick="OpenPointsPerEntryModal">
                                                                                Show all @_model.PointsPerEntry.Count
                                                                            </button>
                                                                        }
                                                                    </section>

                                                                    <section class="stats-section">
                                                                        <div class="stats-section-header stats-accent-blue-300">
                                                                            <h2 class="stats-section-title">Points Per Tournament</h2>
                                                                            @if (_model.MinimumNumberOfTournaments > 0)
                                                                            {
                                                                                <span class="stats-section-qualifier">min @(_model.MinimumNumberOfTournaments.ToString("F1")) tournaments</span>
                                                                            }
                                                                        </div>
                                                                        <div class="stats-table-wrapper">
                                                                            <table class="stats-table">
                                                                                <thead>
                                                                                    <tr>
                                                                                        <th scope="col">Rank</th>
                                                                                        <th scope="col">Name</th>
                                                                                        <th scope="col" class="text-right">Pts / Tourn.</th>
                                                                                        <th scope="col" class="text-right">Total Points</th>
                                                                                        <th scope="col" class="text-right">Tournaments</th>
                                                                                    </tr>
                                                                                </thead>
                                                                                <tbody>
                                                                                    @foreach (var row in _model.PointsPerTournament.Take(10))
                                                                                    {
                                                                                        <tr class="@(row.Rank == 1 ? "stats-row-first" : "stats-row")">
                                                                                            <td class="@(row.Rank == 1 ? "rank-cell rank-cell-accent-blue-300" : "rank-cell")">
                                                                                                @row.Rank</td>
                                                                                                <td><a href="@GetIndividualStatsUrl(row.BowlerId)" class="stats-name-link">@row.BowlerName</a></td>
                                                                                                <td
                                                                                                    class="text-right tabular-nums @(row.Rank == 1 ? "text-[var(--neba-blue-300)]" : "")">
                                                                                                    @row.PointsPerTournament.ToString("F3")
                                                                                                </td>
                                                                                                <td class="text-right tabular-nums">@row.Points</td>
                                                                                                <td class="text-right tabular-nums">@row.Tournaments</td>
                                                                                            </tr>
                                                                                        }
                                                                                    </tbody>
                                                                                </table>
                                                                            </div>
                                                                            @if (_model.PointsPerTournament.Count > 10)
                                                                            {
                                                                                <button class="stats-expand-btn"
                                                                                        aria-label="@($"Show all {_model.PointsPerTournament.Count} Points Per Tournament standings")"
                                                                                        @onclick="OpenPointsPerTournamentModal">
                                                                                    Show all @_model.PointsPerTournament.Count
                                                                                </button>
                                                                            }
                                                                        </section>

                                                                        <section class="stats-section">
                                                                            <div class="stats-section-header stats-accent-blue-300">
                                                                                <h2 class="stats-section-title">Finals Per Entry</h2>
                                                                                @if (_model.MinimumNumberOfEntries > 0)
                                                                                {
                                                                                    <span class="stats-section-qualifier">min @(_model.MinimumNumberOfEntries.ToString("F1")) entries</span>
                                                                                }
                                                                            </div>
                                                                            <div class="stats-table-wrapper">
                                                                                <table class="stats-table">
                                                                                    <thead>
                                                                                        <tr>
                                                                                            <th scope="col">Rank</th>
                                                                                            <th scope="col">Name</th>
                                                                                            <th scope="col" class="text-right">Finals / Entry</th>
                                                                                            <th scope="col" class="text-right">Finals</th>
                                                                                            <th scope="col" class="text-right">Entries</th>
                                                                                        </tr>
                                                                                    </thead>
                                                                                    <tbody>
                                                                                        @foreach (var row in _model.FinalsPerEntry.Take(10))
                                                                                        {
                                                                                            <tr class="@(row.Rank == 1 ? "stats-row-first" : "stats-row")">
                                                                                                <td class="@(row.Rank == 1 ? "rank-cell rank-cell-accent-blue-300" : "rank-cell")">
                                                                                                    @row.Rank</td>
                                                                                                    <td><a href="@GetIndividualStatsUrl(row.BowlerId)" class="stats-name-link">@row.BowlerName</a></td>
                                                                                                    <td
                                                                                                        class="text-right tabular-nums @(row.Rank == 1 ? "text-[var(--neba-blue-300)]" : "")">
                                                                                                        @row.FinalsPerEntry.ToString("F3")
                                                                                                    </td>
                                                                                                    <td class="text-right tabular-nums">@row.Finals</td>
