            return;
        }

        OpenStandingsModal("Average Finish", RenderAverageFinishTable(_model.AverageFinishes));
    }

    private void OpenStandingsModal(string title, RenderFragment content)
    {
        OpenModal($"{title} — Full Standings", content);
    }

    private void OpenProgressionModal(IReadOnlyCollection<PointsRaceSeriesViewModel> series)
    {
        if (_model is null)
        {
            return;
        }

        OpenModal("Points Race", RenderProgressionModal(series), isWide: true);
    }

    private void OpenModal(string title, RenderFragment content, bool isWide = false)
    {
        _modalTitle = title;
        _modalContent = content;
        _modalWide = isWide;
        _modalOpen = true;
    }

    private void CloseModal()
    {
        _modalOpen = false;
        _modalWide = false;
