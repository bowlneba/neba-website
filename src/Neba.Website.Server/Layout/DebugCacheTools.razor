@inject Neba.Website.Server.Services.NebaApiConfiguration ApiConfiguration
@inject IHttpClientFactory HttpClientFactory
@inject Neba.Website.Server.Notifications.ToastService ToastService

@if (IsDebugBuild)
{
    <div class="debug-banner-actions">
        <button class="debug-banner-link" @onclick="ClearApiCacheAsync" type="button">Clear API Cache</button>
        <button class="debug-banner-link" @onclick="SendTestEmailAsync" type="button">Send Test Email</button>
        <a class="debug-banner-link" href="/account/login?admin=1">Log in as Admin</a>
    </div>
}

@code {
    private static bool IsDebugBuild
    {
        get
        {
#if DEBUG
            return true;
#else
            return false;
#endif
        }
    }

    private async Task ClearApiCacheAsync()
    {
        if (!IsDebugBuild)
            return;

        try
        {
            using var client = HttpClientFactory.CreateClient();
            using var response = await client.GetAsync(new Uri(ApiConfiguration.BaseUrl, "/debug/cache"));

            if (response.IsSuccessStatusCode)
            {
                var message = await response.Content.ReadAsStringAsync();
                ToastService.Show("API Cache Cleared",
                    string.IsNullOrWhiteSpace(message) ? "Cache was cleared." : message,
                    NotifySeverity.Success);
            }
            else
            {
                ToastService.Show("Cache Clear Failed", $"API returned {(int)response.StatusCode}.", NotifySeverity.Error);
            }
        }
        catch (Exception ex)
        {
            ToastService.Show("Cache Clear Failed", ex.Message, NotifySeverity.Error);
        }
    }

    private async Task SendTestEmailAsync()
    {
        if (!IsDebugBuild)
            return;

        try
        {
            using var client = HttpClientFactory.CreateClient();
            using var response = await client.GetAsync(new Uri(ApiConfiguration.BaseUrl, "/debug/email"));

            if (response.IsSuccessStatusCode)
            {
                var message = await response.Content.ReadAsStringAsync();
                ToastService.Show("Test Email Sent",
                    string.IsNullOrWhiteSpace(message) ? "Email was sent." : message,
                    NotifySeverity.Success);
            }
            else
            {
                ToastService.Show("Test Email Failed", $"API returned {(int)response.StatusCode}.", NotifySeverity.Error);
            }
        }
        catch (Exception ex)
        {
            ToastService.Show("Test Email Failed", ex.Message, NotifySeverity.Error);
        }
    }
}
