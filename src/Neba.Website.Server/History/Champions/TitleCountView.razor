                        <span class="count-group__num">@group.Count</span>
                        <span class="count-group__label">@(group.Count == 1 ? "title" : "titles")</span>
                        <span class="count-group__tally">@group.Bowlers.Count @(group.Bowlers.Count == 1 ? "bowler" : "bowlers")</span>
                    </div>
                    <div class="count-group__grid">
                        @foreach (var bowler in group.Bowlers)
                        {
                            <button class="bowler-card"
                                    @key="@bowler.BowlerId"
                                    @onclick="@(() => OnBowlerSelected.InvokeAsync(bowler))">
                                <span class="bowler-card__body">
                                    <span class="bowler-card__name">@bowler.BowlerName</span>
                                </span>
                                <span class="bowler-card__count">@bowler.TitleCount</span>
                                @if (bowler.HallOfFame)
                                {
                                    <img src="/images/neba-hof.jpg" class="hof-badge" alt="Hall of Fame" />
                                }
                                <span class="bowler-card__chev"><span class="msym">chevron_right</span></span>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="@TierSectionClass("std")" data-tier="std">
        <div class="tier-head" role="button" tabindex="0"
             @onclick="@(() => ToggleTier("std"))"
             @onkeydown="@(e => { if (e.Key is "Enter" or " ") ToggleTier("std"); })">
            <span class="tier-head__chevron"><span class="msym">expand_more</span></span>
            <span class="tier-head__rule"></span>
            <h2 class="tier-head__title font-display">
                Champions <span class="tier-head__range">1 – 9 titles</span>
            </h2>
            <span class="tier-head__count">@GetStdBowlers().Count bowlers</span>
        </div>
        <div class="tier-body">
            @foreach (var group in GroupByCount(GetStdBowlers()))
            {
                <div class="count-group" @key="@group.Count">
                    <div class="count-group__head">
