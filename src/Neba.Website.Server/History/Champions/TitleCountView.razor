            <span class="tier-head__rule"></span>
            <h2 class="tier-head__title font-display">
                Decorated <span class="tier-head__range">10 – 19 titles</span>
            </h2>
            <span class="tier-head__count">@GetMidBowlers().Count bowlers</span>
        </div>
        <div class="tier-body">
            @foreach (var group in GroupByCount(GetMidBowlers()))
            {
