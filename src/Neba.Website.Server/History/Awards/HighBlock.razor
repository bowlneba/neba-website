@page "/history/high-block"
@using Neba.Api.Contracts.Awards
@using Neba.Website.Server.History.Awards
@using Neba.Website.Server.Services

@inject ApiExecutor ApiExecutor
@inject IAwardsApi AwardsApi

@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>High Block Award - NEBA</PageTitle>
<HeadContent>
    <meta name="description" content="View NEBA High Block award winners by season. Recognizing the highest five-game block scores achieved by bowlers throughout NEBA's history." />
</HeadContent>

<div class="neba-space-y-6">
    <!-- Page Header -->
    <div>
        <h1 class="text-3xl font-bold text-[var(--neba-blue-700)]">High Block</h1>
        <div class="mt-2 text-base text-gray-700 leading-relaxed bg-white/80 rounded-lg shadow-sm p-4 border border-gray-100 max-w-4xl">
            <p>
                The <span class="font-semibold text-[var(--neba-blue-700)]">High Block</span> award recognizes the
                highest five-game block score achieved in a single season, representing exceptional performance across
                five consecutive games during the Qualifying Round.
            </p>
        </div>
    </div>

    <!-- Error Alert -->
    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <NebaAlert Severity="NotifySeverity.Error"
                   Title="Error Loading Awards"
                   Message="@_errorMessage"
                   Dismissible="true"
                   OnDismiss="@(() => _errorMessage = null)" />
    }

    @if (_isLoading)
    {
        <div class="max-w-4xl">
            <NebaSkeletonLoader Type="SkeletonType.Custom" Width="100%" Height="400px" />
        </div>
    }
    else if (_awards.Count > 0)
    {
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm max-w-4xl">
            <table class="w-full">
                <thead class="bg-gray-50 border-b-2 border-[var(--neba-accent-red)]">
                    <tr>
                        <th class="px-6 py-3 text-left text-sm font-bold text-gray-700 w-36">Year</th>
                        <th class="px-6 py-3 text-left text-sm font-bold text-gray-700">Bowler(s)</th>
                        <th class="px-6 py-3 text-right text-sm font-bold text-gray-700 w-32">Score</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var award in _awards)
                    {
                        var hasTie = award.Bowlers.Count > 1;
                        var isRecord = award.Score == _recordScore;

                        string rowClass;
                        if (isRecord)
                        {
                            rowClass = "bg-amber-50 hover:bg-gray-50 border-l-4 border-amber-500";
                        }
                        else if (hasTie)
                        {
                            rowClass = "bg-blue-50 hover:bg-blue-100 border-l-4 border-[var(--neba-blue-700)]";
                        }
                        else
                        {
                            rowClass = "hover:bg-gray-50";
                        }

                        <tr class="@rowClass">
                            <td class="px-6 py-4 text-gray-900 font-semibold">@award.Season</td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    @if (isRecord)
                                    {
                                        <span class="text-xs font-bold text-amber-600 bg-white px-2 py-0.5 rounded border border-amber-300" title="All-time record">RECORD</span>
                                    }
                                    @if (hasTie)
                                    {
                                        <span class="text-xs font-bold text-[var(--neba-blue-700)] bg-white px-2 py-0.5 rounded">TIE</span>
                                    }
                                    <span class="text-gray-900">@string.Join(", ", award.Bowlers)</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-gray-900 font-bold text-right @(isRecord ? "text-lg" : "")">@award.Score</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-12 text-gray-500">
            <p>No high block awards data available.</p>
        </div>
    }
</div>

@code {
    private List<HighBlockAwardViewModel> _awards = [];
    private string? _errorMessage;
    private bool _isLoading = true;
    private int _recordScore;

    protected override async Task OnInitializedAsync()
    {
        var result = await ApiExecutor.ExecuteAsync(
            "Awards",
            "ListHighBlockAwards",
            ct => AwardsApi.ListHighBlockAwardsAsync(ct));

        _isLoading = false;

        if (result.IsError)
        {
            _errorMessage = result.FirstError.Description;
            return;
        }

        _awards = [.. result.Value.Items.ToViewModels().OrderByDescending(a => a.Season)];
        _recordScore = _awards.Count > 0 ? _awards.Max(a => a.Score) : 0;
    }
}
