@page "/history/high-average"
@using Neba.Api.Contracts.Awards
@using Neba.Website.Server.History.Awards
@using Neba.Website.Server.Services

@inject ApiExecutor ApiExecutor
@inject IAwardsApi AwardsApi

@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>High Average Award - NEBA</PageTitle>
<HeadContent>
    <meta name="description" content="View NEBA High Average award winners by season. Recognizing the highest bowling averages achieved by bowlers throughout NEBA's history." />
</HeadContent>

<div class="neba-space-y-6">
    <!-- Page Header -->
    <div>
        <h1 class="text-3xl font-bold text-[var(--neba-blue-700)]">High Average</h1>
        <div class="mt-2 text-base text-gray-700 leading-relaxed bg-white/80 rounded-lg shadow-sm p-4 border border-gray-100 max-w-4xl">
            <p class="mb-2">
                The <span class="font-semibold text-[var(--neba-blue-700)]">High Average</span> award recognizes the
                highest season-long average achieved by a bowler, demonstrating sustained excellence across an entire
                competitive season.
            </p>
            <p>
                This prestigious achievement showcases a bowler's ability to maintain consistently high scores
                throughout the season, representing the pinnacle of competitive performance.
            </p>
        </div>
    </div>

    <!-- Error Alert -->
    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <NebaAlert Severity="NotifySeverity.Error"
                   Title="Error Loading Awards"
                   Message="@_errorMessage"
                   Dismissible="true"
                   OnDismiss="@(() => _errorMessage = null)" />
    }

    @if (_isLoading)
    {
        <div class="max-w-4xl">
            <NebaSkeletonLoader Type="SkeletonType.Custom" Width="100%" Height="400px" />
        </div>
    }
    else if (_awards.Count > 0)
    {
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm max-w-4xl">
            <table class="w-full">
                <thead class="bg-gray-50 border-b-2 border-[var(--neba-accent-red)]">
                    <tr>
                        <th class="px-6 py-3 text-left text-sm font-bold text-gray-700 w-36">Year</th>
                        <th class="px-6 py-3 text-left text-sm font-bold text-gray-700">Bowler</th>
                        <th class="px-6 py-3 text-right text-sm font-bold text-gray-700 w-24">Avg.</th>
                        <th class="px-6 py-3 text-center text-sm font-bold text-gray-700 w-24 hidden sm:table-cell">Games</th>
                        <th class="px-6 py-3 text-center text-sm font-bold text-gray-700 w-28 hidden sm:table-cell">Tournaments</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var award in _awards)
                    {
                        var isRecord = award.Average == _recordAverage;
                        var rowClass = isRecord
                            ? "bg-amber-50 hover:bg-gray-50 border-l-4 border-amber-500"
                            : "hover:bg-gray-50";

                        <tr class="@rowClass">
                            <td class="px-6 py-4 text-gray-900 font-semibold">@award.Season</td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    @if (isRecord)
                                    {
                                        <span class="text-xs font-bold text-amber-600 bg-white px-2 py-0.5 rounded border border-amber-300" title="All-time record">RECORD</span>
                                    }
                                    <span class="text-gray-900">@award.BowlerName</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-gray-900 font-bold text-right @(isRecord ? "text-lg" : "")">@award.Average.ToString("F2")</td>
                            <td class="px-6 py-4 text-center hidden sm:table-cell">
                                @if (award.TotalGames.HasValue)
                                {
                                    <span class="text-gray-900">@award.TotalGames.Value</span>
                                }
                                else
                                {
                                    <span class="text-gray-500">—</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-center hidden sm:table-cell">
                                @if (award.TournamentsParticipated.HasValue)
                                {
                                    <span class="text-gray-900">@award.TournamentsParticipated.Value</span>
                                }
                                else
                                {
                                    <span class="text-gray-500">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-12 text-gray-500">
            <p>No high average awards data available.</p>
        </div>
    }
</div>

@code {
    private List<HighAverageAwardViewModel> _awards = [];
    private string? _errorMessage;
    private bool _isLoading = true;
    private decimal _recordAverage;

    protected override async Task OnInitializedAsync()
    {
        var result = await ApiExecutor.ExecuteAsync(
            "Awards",
            "ListHighAverageAwards",
            ct => AwardsApi.ListHighAverageAwardsAsync(ct));

        _isLoading = false;

        if (result.IsError)
        {
            _errorMessage = result.FirstError.Description;
            return;
        }

        _awards = [.. result.Value.Items
            .Select(r => r.ToViewModel())
            .OrderByDescending(a => a.Season)];
        _recordAverage = _awards.Count > 0 ? _awards.Max(a => a.Average) : 0;
    }
}
