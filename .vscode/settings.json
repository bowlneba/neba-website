{
    "cSpell.words": [
      "Antiforgery",
      "apphost",
      "apphosts",
      "Ardalis",
      "Blazor",
      "bowlneba",
      "Challonge",
      "diagnosability",
      "Fluxor",
      "Instantiator",
      "kippermand",
      "Neba",
      "Npgsql",
      "Provisionable",
      "psql",
      "Respawn",
      "Shouldly",
      "sonarcloud",
      "SonarQube",
      "Synchronisation",
      "USBC",
      "viewports",
      "Xunit"
    ],
    "cSpell.ignorePaths": [
        ".gitignore",
        "**/.editorconfig",
        "**/*.csproj",
        ".vscode/**",
        "**/*.props",
        ".github/workflows/**"
    ],
    "sonarlint.connectedMode.project": {
      "connectionId": "bowlneba",
      "projectKey": "bowlneba-website"
    },
    "dotnet.defaultSolution": "Neba.Website.slnx",
    "testExplorer.useNativeTesting": true,
    "dotnet.testWindow.useTestingPlatformProtocol": true,
    "dotnet-test-explorer.testProjectPath": "tests/**/*.csproj",
    "dotnet.unitTests.runSettingsPath": "${workspaceFolder}/.runsettings",
    "chat.tools.terminal.autoApprove": {
      "dotnet ef": true
    },
    "[csharp]": {
      "editor.formatOnSave": true,
      "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit"
      }
    },
    "razor.format.enable": false,
    "[razor]": {
      "editor.formatOnSave": false
    }
}