{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": ["html", "progress", "dashboard"],
  "testRunner": "jest",
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "dashboard": {
    "project": "github.com/bowlneba/neba-website",
    "module": "website-js",
    "version": "main"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 0
  },
  "mutate": [
    "src/Neba.Website.Server/**/*.js",
    "!src/Neba.Website.Server/**/*.tests.js",
    "!src/Neba.Website.Server/**/*.test.js",
    "!src/Neba.Website.Server/wwwroot/js/tailwind.config.js"
  ],
  "ignorePatterns": [
    "node_modules",
    "tests/e2e",
    "coverage",
    "reports",
    "playwright-report",
    "test-results"
  ],
  "jest": {
    "configFile": "./jest.config.js"
  }
}
